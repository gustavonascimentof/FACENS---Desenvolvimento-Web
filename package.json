{
  "name": "cone-trufado-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "E-commerce Cone Trufado - Frontend + Backend",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "cd web && vite",
    "dev:api": "cd api && nodemon src/server.js",
    "build": "cd web && vite build",
    "preview": "cd web && vite preview",
    "lint": "cd web && eslint .",
    "start": "cd api && node src/server.js"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^7.2.0",
    "mongoose": "^7.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "nodemon": "^3.0.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.10"
  }
}
